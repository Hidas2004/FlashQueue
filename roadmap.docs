4.5 RabbitMQ (UPDATED — Fix Bug 3 + DLQ)
internal/queue/rabbitmq.go
Bug 3 fix: Mỗi consumer tạo channel riêng, không share channel giữa goroutines
go
package queue

import (
    "context"
    "encoding/json"
    "fmt"
    "log"
    "time"

    amqp "github.com/rabbitmq/amqp091-go"
)

type RabbitMQ struct {
    conn      *amqp.Connection
    QueueName string
    DLQName   string
}

func NewRabbitMQ(url, queueName, dlqName string) (*RabbitMQ, error) {
    conn, err := amqp.Dial(url)
    if err != nil {
        return nil, fmt.Errorf("dial rabbitmq: %w", err)
    }

    // Setup queues trên 1 channel tạm (chỉ để declare)
    ch, err := conn.Channel()
    if err != nil {
        return nil, err
    }
    defer ch.Close()

    // Khai báo DLQ trước
    _, err = ch.QueueDeclare(dlqName, true, false, false, false, nil)
    if err != nil {
        return nil, fmt.Errorf("declare DLQ: %w", err)
    }

    // Khai báo main queue với DLX (Dead Letter Exchange) trỏ về DLQ
    _, err = ch.QueueDeclare(
        queueName, true, false, false, false,
        amqp.Table{
            "x-dead-letter-exchange":    "",      // default exchange
            "x-dead-letter-routing-key": dlqName, // route sang DLQ
            "x-message-ttl":             int32(86400000),
        },
    )
    if err != nil {
        return nil, fmt.Errorf("declare main queue: %w", err)
    }

    log.Printf("RabbitMQ ready. Queue: %s, DLQ: %s", queueName, dlqName)
    return &RabbitMQ{conn: conn, QueueName: queueName, DLQName: dlqName}, nil
}

func (r *RabbitMQ) Publish(ctx context.Context, msg interface{}) error {
    // Mỗi Publish dùng channel riêng — thread safe
    ch, err := r.conn.Channel()
    if err != nil {
        return err
    }
    defer ch.Close()

    body, err := json.Marshal(msg)
    if err != nil {
        return err
    }

    return ch.PublishWithContext(ctx, "", r.QueueName, false, false,
        amqp.Publishing{
            ContentType:  "application/json",
            DeliveryMode: amqp.Persistent,
            Timestamp:    time.Now(),
            Body:         body,
        },
    )
}

// NewConsumerChannel — Bug 3 fix: mỗi worker tạo channel consumer RIÊNG
func (r *RabbitMQ) NewConsumerChannel() (*amqp.Channel, <-chan amqp.Delivery, error) {
    ch, err := r.conn.Channel()
    if err != nil {
        return nil, nil, err
    }
    // Prefetch 1: worker chỉ nhận 1 message tại 1 thời điểm
    ch.Qos(1, 0, false)

    deliveries, err := ch.Consume(r.QueueName, "", false, false, false, false, nil)
    if err != nil {
        ch.Close()
        return nil, nil, err
    }
    return ch, deliveries, nil
}

func (r *RabbitMQ) PublishToDLQ(ctx context.Context, msg interface{}) error {
    ch, err := r.conn.Channel()
    if err != nil {
        return err
    }
    defer ch.Close()

    body, err := json.Marshal(msg)
    if err != nil {
        return err
    }

    return ch.PublishWithContext(ctx, "", r.DLQName, false, false,
        amqp.Publishing{
            ContentType:  "application/json",
            DeliveryMode: amqp.Persistent,
            Timestamp:    time.Now(),
            Body:         body,
        },
    )
}

func (r *RabbitMQ) Close() {
    r.conn.Close()
}
