4.13 Worker Main (UPDATED — Poller + Zap + Graceful shutdown)
cmd/worker/main.go
go
package main

import (
    "context"
    "os"
    "os/signal"
    "syscall"

    "go.uber.org/zap"

    "job-scheduler/internal/config"
    "job-scheduler/internal/db"
    "job-scheduler/internal/job"
    "job-scheduler/internal/queue"
    "job-scheduler/internal/worker"
)

func main() {
    logger, _ := zap.NewProduction()
    defer logger.Sync()
    sugar := logger.Sugar()

    cfg := config.Load()

    database := db.NewPostgres(cfg.DatabaseURL)
    defer database.Close()

    mq, err := queue.NewRabbitMQ(cfg.RabbitMQURL, cfg.QueueName, cfg.DLQName)
    if err != nil {
        sugar.Fatalf("RabbitMQ connect: %v", err)
    }
    defer mq.Close()

    repo := job.NewRepository(database)
    pool := worker.NewPool(cfg.WorkerCount, repo, mq, cfg.RetryDelay)
    poller := worker.NewRetryPoller(repo, mq, 10) // Poll mỗi 10 giây

    ctx, cancel := context.WithCancel(context.Background())

    quit := make(chan os.Signal, 1)
    signal.Notify(quit, syscall.SIGINT, syscall.SIGTERM)
    go func() {
        <-quit
        sugar.Info("Shutdown signal received")
        cancel()
    }()

    // Chạy retry poller song song với worker pool
    go poller.Start(ctx)

    sugar.Infof("Worker pool starting with %d workers", cfg.WorkerCount)
    if err := pool.Start(ctx); err != nil {
        sugar.Fatalf("Pool error: %v", err)
    }
}
