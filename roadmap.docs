4.4 Repository (UPDATED — Fix Bug 1 & Bug 2)
internal/job/repository.go
Bug 1 fix: Dùng FOR UPDATE SKIP LOCKED — chuẩn production PostgreSQL queue
Bug 2 fix: Viết lại List() dùng sqlx đúng cách, không còn lỗi itoa/args
go
package job

import (
    "fmt"
    "strconv"
    "time"

    "github.com/jmoiron/sqlx"
)

type Repository struct {
    db *sqlx.DB
}

func NewRepository(db *sqlx.DB) *Repository {
    return &Repository{db: db}
}

// ClaimJob — Senior pattern: FOR UPDATE SKIP LOCKED
// Đảm bảo 1 job chỉ được 1 worker xử lý, KHÔNG có race condition
// Nhiều worker gọi đồng thời sẽ tự động lấy các job KHÁC NHAU
func (r *Repository) ClaimJob(jobID string) (*Job, error) {
    tx, err := r.db.Beginx()
    if err != nil {
        return nil, err
    }
    defer tx.Rollback()

    var j Job
    err = tx.Get(&j, `
        SELECT * FROM jobs
        WHERE id = $1 AND status IN ('pending', 'retrying')
        FOR UPDATE SKIP LOCKED
    `, jobID)
    if err != nil {
        return nil, err // job đã bị worker khác lấy → skip
    }

    _, err = tx.Exec(`
        UPDATE jobs SET status = 'running', started_at = NOW() WHERE id = $1
    `, jobID)
    if err != nil {
        return nil, err
    }

    if err := tx.Commit(); err != nil {
        return nil, err
    }
    return &j, nil
}

func (r *Repository) Create(req *CreateJobRequest) (*Job, error) {
    maxRetries := req.MaxRetries
    if maxRetries == 0 {
        maxRetries = 3
    }
    payload := req.Payload
    if payload == nil {
        payload = []byte("{}")
    }

    var j Job
    err := r.db.Get(&j, `
        INSERT INTO jobs (type, payload, priority, max_retries, scheduled_at)
        VALUES ($1, $2, $3, $4, $5)
        RETURNING *
    `, req.Type, payload, req.Priority, maxRetries, req.ScheduledAt)
    return &j, err
}

func (r *Repository) GetByID(id string) (*Job, error) {
    var j Job
    err := r.db.Get(&j, `SELECT * FROM jobs WHERE id = $1`, id)
    return &j, err
}

func (r *Repository) MarkCompleted(id string) error {
    _, err := r.db.Exec(`
        UPDATE jobs SET status = 'completed', completed_at = NOW() WHERE id = $1
    `, id)
    return err
}

// MarkFailed — xử lý cả retry với exponential backoff
func (r *Repository) MarkFailed(id string, errMsg string, shouldRetry bool, retryDelaySec int) error {
    if !shouldRetry {
        _, err := r.db.Exec(`
            UPDATE jobs SET status = 'dead', error_message = $1 WHERE id = $2
        `, errMsg, id)
        return err
    }

    // Exponential backoff: delay = retryDelaySec * 2^retry_count + jitter
    // Tính toán trong DB bằng retry_count hiện tại
    _, err := r.db.Exec(`
        UPDATE jobs
        SET status = 'retrying',
            error_message = $1,
            retry_count = retry_count + 1,
            next_retry_at = NOW() + (($2 * POWER(2, retry_count)) || ' seconds')::INTERVAL
        WHERE id = $3
    `, errMsg, retryDelaySec, id)
    return err
}

// MarkDead — đưa job vào trạng thái dead (đã hết retry)
func (r *Repository) MarkDead(id string, errMsg string) error {
    _, err := r.db.Exec(`
        UPDATE jobs SET status = 'dead', error_message = $1 WHERE id = $2
    `, errMsg, id)
    return err
}

// List — FIXED: không còn lỗi itoa / args sai
func (r *Repository) List(status string, limit, offset int) ([]*Job, int, error) {
    where := ""
    args := []interface{}{}

    if status != "" {
        where = "WHERE status = $1"
        args = append(args, status)
    }

    // Count query
    var total int
    if err := r.db.Get(&total, "SELECT COUNT(*) FROM jobs "+where, args...); err != nil {
        return nil, 0, err
    }

    // Build data query với đúng thứ tự $N
    argIdx := len(args) + 1
    dataQuery := fmt.Sprintf(
        `SELECT * FROM jobs %s ORDER BY priority DESC, created_at DESC LIMIT $%s OFFSET $%s`,
        where,
        strconv.Itoa(argIdx),
        strconv.Itoa(argIdx+1),
    )
    args = append(args, limit, offset)

    var jobs []*Job
    if err := r.db.Select(&jobs, dataQuery, args...); err != nil {
        return nil, 0, err
    }
    return jobs, total, nil
}

func (r *Repository) GetStats() (map[string]int, error) {
    rows, err := r.db.Queryx(`SELECT status, COUNT(*) as count FROM jobs GROUP BY status`)
    if err != nil {
        return nil, err
    }
    defer rows.Close()

    stats := map[string]int{}
    for rows.Next() {
        var s struct {
            Status string `db:"status"`
            Count  int    `db:"count"`
        }
        rows.StructScan(&s)
        stats[s.Status] = s.Count
    }
    return stats, nil
}

// GetDueRetryJobs — Scheduled Job Poller dùng cái này
func (r *Repository) GetDueRetryJobs() ([]*Job, error) {
    var jobs []*Job
    err := r.db.Select(&jobs, `
        SELECT * FROM jobs
        WHERE status = 'retrying' AND next_retry_at <= NOW()
        ORDER BY priority DESC, next_retry_at
        LIMIT 100
        FOR UPDATE SKIP LOCKED
    `)
    return jobs, err
}
