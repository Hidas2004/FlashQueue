4.7 Worker Pool (UPDATED — Exponential Backoff + Metrics + Bug 3 fix)
internal/worker/processor.go
go
package worker

import (
    "context"
    "encoding/json"
    "fmt"
    "log"
    "math/rand"
    "time"

    "job-scheduler/internal/job"
)

type ProcessorFunc func(ctx context.Context, j *job.Job) error

var defaultProcessors = map[job.Type]ProcessorFunc{
    job.TypeSendEmail:       processSendEmail,
    job.TypeProcessImage:    processImage,
    job.TypeGenerateReport:  processGenerateReport,
    job.TypeDataCalculation: processDataCalculation,
}

func processSendEmail(ctx context.Context, j *job.Job) error {
    var payload struct {
        To      string `json:"to"`
        Subject string `json:"subject"`
    }
    json.Unmarshal(j.Payload, &payload)
    log.Printf("[SendEmail] Sending to %s: %s", payload.To, payload.Subject)

    // Giả lập 10% network failure để test retry
    if rand.Intn(10) == 0 {
        return fmt.Errorf("network timeout sending email to %s", payload.To)
    }
    time.Sleep(500 * time.Millisecond)
    return nil
}

func processImage(ctx context.Context, j *job.Job) error {
    log.Printf("[ProcessImage] Processing %s", j.ID)
    time.Sleep(2 * time.Second)
    return nil
}

func processGenerateReport(ctx context.Context, j *job.Job) error {
    log.Printf("[GenerateReport] Generating %s", j.ID)
    time.Sleep(3 * time.Second)
    return nil
}

func processDataCalculation(ctx context.Context, j *job.Job) error {
    log.Printf("[DataCalculation] Calculating %s", j.ID)
    time.Sleep(1 * time.Second)
    return nil
}
internal/worker/pool.go
go
package worker

import (
    "context"
    "encoding/json"
    "fmt"
    "log"
    "sync"
    "time"

    amqp "github.com/rabbitmq/amqp091-go"
    "job-scheduler/internal/job"
    "job-scheduler/internal/metrics"
    "job-scheduler/internal/queue"
)

type Pool struct {
    workerCount   int
    repo          *job.Repository
    queue         *queue.RabbitMQ
    processors    map[job.Type]ProcessorFunc
    retryDelaySec int
    wg            sync.WaitGroup
}

func NewPool(workerCount int, repo *job.Repository, q *queue.RabbitMQ, retryDelaySec int) *Pool {
    return &Pool{
        workerCount:   workerCount,
        repo:          repo,
        queue:         q,
        processors:    defaultProcessors,
        retryDelaySec: retryDelaySec,
    }
}

func (p *Pool) Start(ctx context.Context) error {
    log.Printf("Starting %d workers", p.workerCount)

    for i := 0; i < p.workerCount; i++ {
        // Bug 3 fix: mỗi worker tạo channel consumer riêng
        ch, deliveries, err := p.queue.NewConsumerChannel()
        if err != nil {
            return fmt.Errorf("worker %d: create consumer channel: %w", i+1, err)
        }

        p.wg.Add(1)
        go p.runWorker(ctx, i+1, ch, deliveries)
    }

    <-ctx.Done()
    log.Println("Waiting for all workers to finish...")
    p.wg.Wait()
    log.Println("All workers stopped cleanly")
    return nil
}

func (p *Pool) runWorker(ctx context.Context, id int, ch *amqp.Channel, deliveries <-chan amqp.Delivery) {
    defer p.wg.Done()
    defer ch.Close() // Mỗi worker tự đóng channel riêng của mình
    log.Printf("Worker %d started", id)

    for {
        select {
        case <-ctx.Done():
            log.Printf("Worker %d: shutting down", id)
            return
        case delivery, ok := <-deliveries:
            if !ok {
                log.Printf("Worker %d: channel closed", id)
                return
            }
            p.processDelivery(ctx, id, delivery)
        }
    }
}

func (p *Pool) processDelivery(ctx context.Context, workerID int, delivery amqp.Delivery) {
    var msg job.JobMessage
    if err := json.Unmarshal(delivery.Body, &msg); err != nil {
        log.Printf("Worker %d: invalid message body: %v", workerID, err)
        delivery.Nack(false, false)
        return
    }

    // FOR UPDATE SKIP LOCKED: đảm bảo chỉ 1 worker xử lý job này
    j, err := p.repo.ClaimJob(msg.JobID)
    if err != nil {
        // Job đã được worker khác claim → skip bình thường
        log.Printf("Worker %d: job %s already claimed or not found, skipping", workerID, msg.JobID)
        delivery.Ack(false)
        return
    }

    log.Printf("Worker %d: claimed job %s (type: %s, retry: %d/%d)",
        workerID, j.ID, j.Type, j.RetryCount, j.MaxRetries)

    processor, exists := p.processors[j.Type]
    if !exists {
        p.repo.MarkDead(j.ID, fmt.Sprintf("no processor for type: %s", j.Type))
        delivery.Ack(false)
        return
    }

    // Track processing time cho Prometheus
    startTime := time.Now()
    jobCtx, cancel := context.WithTimeout(ctx, 30*time.Second)
    defer cancel()

    err = processor(jobCtx, j)
    duration := time.Since(startTime).Seconds()

    if err == nil {
        p.repo.MarkCompleted(j.ID)
        metrics.JobsProcessedTotal.WithLabelValues(string(j.Type), "completed").Inc()
        metrics.JobProcessingDuration.WithLabelValues(string(j.Type)).Observe(duration)
        log.Printf("Worker %d: job %s COMPLETED in %.2fs", workerID, j.ID, duration)
        delivery.Ack(false)
        return
    }

    // Xử lý lỗi
    shouldRetry := j.RetryCount < j.MaxRetries
    log.Printf("Worker %d: job %s FAILED (retry %d/%d): %v",
        workerID, j.ID, j.RetryCount+1, j.MaxRetries, err)

    metrics.JobsProcessedTotal.WithLabelValues(string(j.Type), "failed").Inc()

    if shouldRetry {
        // Exponential backoff: delay = retryDelaySec * 2^retry_count
        // Tính trong DB (xem MarkFailed), worker chỉ cần re-enqueue sau khi next_retry_at đến
        p.repo.MarkFailed(j.ID, err.Error(), true, p.retryDelaySec)
        metrics.JobsRetryTotal.WithLabelValues(string(j.Type)).Inc()
        // Re-publish vào queue (scheduled poller sẽ push lại khi next_retry_at đến)
        delivery.Ack(false)
        return
    }

    // Hết retry → đánh dấu dead + đẩy vào DLQ
    p.repo.MarkDead(j.ID, err.Error())
    dlqMsg := map[string]interface{}{
        "job_id":        j.ID,
        "type":          j.Type,
        "error":         err.Error(),
        "retry_count":   j.RetryCount + 1,
        "failed_at":     time.Now(),
    }
    if pubErr := p.queue.PublishToDLQ(ctx, dlqMsg); pubErr != nil {
        log.Printf("Worker %d: failed to publish to DLQ: %v", workerID, pubErr)
    }
    log.Printf("Worker %d: job %s moved to DLQ after %d retries", workerID, j.ID, j.MaxRetries)
    delivery.Ack(false)
}
