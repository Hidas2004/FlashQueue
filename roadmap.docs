4.8 Scheduled Job Poller (Retry Poller)
internal/worker/poller.go
go
package worker

import (
    "context"
    "log"
    "time"

    "job-scheduler/internal/job"
    "job-scheduler/internal/queue"
)

type RetryPoller struct {
    repo     *job.Repository
    queue    *queue.RabbitMQ
    interval time.Duration
}

func NewRetryPoller(repo *job.Repository, q *queue.RabbitMQ, intervalSec int) *RetryPoller {
    return &RetryPoller{
        repo:     repo,
        queue:    q,
        interval: time.Duration(intervalSec) * time.Second,
    }
}

// Start chạy mỗi N giây, tìm các job retrying có next_retry_at <= NOW()
// rồi re-enqueue chúng vào RabbitMQ
func (p *RetryPoller) Start(ctx context.Context) {
    ticker := time.NewTicker(p.interval)
    defer ticker.Stop()
    log.Printf("Retry poller started, interval: %v", p.interval)

    for {
        select {
        case <-ctx.Done():
            log.Println("Retry poller stopped")
            return
        case <-ticker.C:
            p.poll(ctx)
        }
    }
}

func (p *RetryPoller) poll(ctx context.Context) {
    jobs, err := p.repo.GetDueRetryJobs()
    if err != nil {
        log.Printf("Retry poller: query error: %v", err)
        return
    }
    if len(jobs) == 0 {
        return
    }

    log.Printf("Retry poller: found %d jobs ready to retry", len(jobs))
    for _, j := range jobs {
        msg := job.JobMessage{JobID: j.ID, Type: j.Type}
        if err := p.queue.Publish(ctx, msg); err != nil {
            log.Printf("Retry poller: failed to enqueue job %s: %v", j.ID, err)
            continue
        }
        log.Printf("Retry poller: re-enqueued job %s", j.ID)
    }
}
