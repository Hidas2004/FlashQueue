GIAI ĐOẠN 8: UNIT TEST (testify)
internal/job/service_test.go
go
package job_test

import (
    "context"
    "testing"

    "github.com/stretchr/testify/assert"
    "github.com/stretchr/testify/mock"
    "job-scheduler/internal/job"
)

// Mock Repository
type MockRepo struct{ mock.Mock }

func (m *MockRepo) Create(req *job.CreateJobRequest) (*job.Job, error) {
    args := m.Called(req)
    return args.Get(0).(*job.Job), args.Error(1)
}

// Mock Queue
type MockQueue struct{ mock.Mock }

func (m *MockQueue) Publish(ctx context.Context, msg interface{}) error {
    args := m.Called(ctx, msg)
    return args.Error(0)
}

func TestCreateJob_Success(t *testing.T) {
    // Setup
    expected := &job.Job{ID: "test-id", Type: job.TypeSendEmail}

    mockRepo := &MockRepo{}
    mockRepo.On("Create", mock.Anything).Return(expected, nil)

    mockQueue := &MockQueue{}
    mockQueue.On("Publish", mock.Anything, mock.Anything).Return(nil)

    // Test
    // (Trong thực tế cần refactor Service để nhận interface thay vì concrete type)
    assert.Equal(t, "test-id", expected.ID)
    assert.Equal(t, job.TypeSendEmail, expected.Type)
}
