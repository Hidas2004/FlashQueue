GIAI ĐOẠN 6: MAKEFILE (UPDATED)
makefile
.PHONY: up down migrate api worker test-job test-bulk lint test

up:
	docker-compose up -d

down:
	docker-compose down -v

migrate:
	psql "postgres://jobuser:jobpass@localhost:5432/jobscheduler?sslmode=disable" \
		-f internal/db/migrations/001_init.sql

api:
	go run cmd/api/main.go

worker:
	go run cmd/worker/main.go

lint:
	golangci-lint run ./...

test:
	go test ./... -v -race -timeout 30s

test-job:
	curl -s -X POST http://localhost:8080/api/v1/jobs \
		-H "Content-Type: application/json" \
		-d '{"type":"send_email","payload":{"to":"test@example.com","subject":"Hello"},"max_retries":3}' | jq

test-bulk:
	@for i in $$(seq 1 20); do \
		curl -s -X POST http://localhost:8080/api/v1/jobs \
			-H "Content-Type: application/json" \
			-d "{\"type\":\"send_email\",\"payload\":{\"to\":\"user$$i@test.com\",\"subject\":\"Report $$i\"},\"max_retries\":3}" > /dev/null; \
		echo "Sent job $$i"; \
	done

build:
	docker build -f Dockerfile.api -t job-scheduler-api .
	docker build -f Dockerfile.worker -t job-scheduler-worker .

stats:
	curl -s http://localhost:8080/api/dashboard/stats | jq

metrics:
	curl -s http://localhost:8080/metrics | grep jobs_
