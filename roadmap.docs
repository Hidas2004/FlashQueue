go
package dashboard

import (
    "net/http"

    "github.com/gin-gonic/gin"
    "job-scheduler/internal/job"
)

type Handler struct {
    repo *job.Repository
}

func NewHandler(repo *job.Repository) *Handler {
    return &Handler{repo: repo}
}

func (h *Handler) RegisterRoutes(r *gin.RouterGroup) {
    r.GET("/stats", h.GetStats)
    r.GET("/", h.ServeUI)
}

func (h *Handler) GetStats(c *gin.Context) {
    stats, err := h.repo.GetStats()
    if err != nil {
        c.JSON(http.StatusInternalServerError, gin.H{"error": err.Error()})
        return
    }
    total := 0
    for _, v := range stats {
        total += v
    }
    stats["total"] = total
    c.JSON(http.StatusOK, stats)
}

func (h *Handler) ServeUI(c *gin.Context) {
    html := `<!DOCTYPE html>
<html>
<head>
    <title>Job Scheduler Dashboard</title>
    <style>
        * { box-sizing: border-box; }
        body { font-family: -apple-system, Arial, sans-serif; margin: 0; background: #0f172a; color: #e2e8f0; }
        .header { background: #1e293b; padding: 20px 40px; border-bottom: 1px solid #334155; }
        .header h1 { margin: 0; color: #38bdf8; font-size: 1.5em; }
        .content { padding: 30px 40px; }
        .cards { display: flex; gap: 16px; flex-wrap: wrap; margin-bottom: 30px; }
        .card { background: #1e293b; padding: 20px 24px; border-radius: 10px; min-width: 130px; text-align: center; border: 1px solid #334155; }
        .card p { margin: 0 0 8px; color: #94a3b8; font-size: 0.85em; text-transform: uppercase; }
        .card h2 { margin: 0; font-size: 2.2em; }
        .pending { color: #f59e0b; } .running { color: #38bdf8; }
        .completed { color: #10b981; } .failed { color: #ef4444; }
        .retrying { color: #a78bfa; } .dead { color: #6b7280; }
        table { width: 100%; border-collapse: collapse; background: #1e293b; border-radius: 10px; overflow: hidden; }
        th { background: #0f172a; color: #94a3b8; padding: 12px 16px; text-align: left; font-size: 0.8em; text-transform: uppercase; }
        td { padding: 12px 16px; border-bottom: 1px solid #334155; font-size: 0.9em; }
        tr:last-child td { border: none; }
        .badge { padding: 3px 10px; border-radius: 12px; font-size: 0.8em; font-weight: 600; }
        .badge.pending { background: #451a03; color: #f59e0b; }
        .badge.running { background: #0c2a4a; color: #38bdf8; }
        .badge.completed { background: #052e16; color: #10b981; }
        .badge.failed { background: #450a0a; color: #ef4444; }
        .badge.retrying { background: #2e1065; color: #a78bfa; }
        .badge.dead { background: #1c1917; color: #6b7280; }
        .refresh { background: #38bdf8; color: #0f172a; border: none; padding: 8px 18px; border-radius: 6px; cursor: pointer; font-weight: 600; margin-bottom: 20px; }
        .live-dot { width: 8px; height: 8px; background: #10b981; border-radius: 50%; display: inline-block; margin-right: 6px; animation: pulse 1.5s infinite; }
        @keyframes pulse { 0%,100%{opacity:1} 50%{opacity:0.4} }
    </style>
</head>
<body>
    <div class="header">
        <h1><span class="live-dot"></span>Job Scheduler Dashboard</h1>
    </div>
    <div class="content">
        <button class="refresh" onclick="loadData()">↻ Refresh</button>
        <div class="cards" id="stats"></div>
        <h3 style="color:#94a3b8; margin-bottom:12px">Recent Jobs</h3>
        <div id="jobs-table"></div>
    </div>
    <script>
    async function loadData() {
        const [statsRes, jobsRes] = await Promise.all([
            fetch('/api/dashboard/stats'),
            fetch('/api/v1/jobs?limit=20')
        ]);
        const stats = await statsRes.json();
        const data = await jobsRes.json();

        document.getElementById('stats').innerHTML = ['pending','running','completed','failed','retrying','dead','total']
            .map(s => `<div class="card"><p>${s}</p><h2 class="${s}">${stats[s]||0}</h2></div>`)
            .join('');

        const rows = (data.jobs||[]).map(j => `
            <tr>
                <td style="font-family:monospace;color:#94a3b8">${j.id.substring(0,8)}…</td>
                <td>${j.type}</td>
                <td><span class="badge ${j.status}">${j.status}</span></td>
                <td style="color:#94a3b8">${j.retry_count}/${j.max_retries}</td>
                <td style="color:#64748b">${new Date(j.created_at).toLocaleString()}</td>
                <td style="color:#ef4444;font-size:0.8em">${j.error_message||''}</td>
            </tr>`).join('');
        document.getElementById('jobs-table').innerHTML =
            `<table><tr><th>ID</th><th>Type</th><th>Status</th><th>Retries</th><th>Created</th><th>Error</th></tr>${rows}</table>`;
    }
    loadData();
    setInterval(loadData, 3000);
    </script>
</body>
</html>`
    c.Header("Content-Type", "text/html")
    c.String(http.StatusOK, html)
}
