GIAI ĐOẠN 4: CODE TỪNG LAYER
4.1 Config
internal/config/config.go
go
package config

import (
    "log"
    "os"
    "strconv"

    "github.com/joho/godotenv"
)

type Config struct {
    ServerPort      string
    MetricsPort     string
    DatabaseURL     string
    RabbitMQURL     string
    WorkerCount     int
    QueueName       string
    DLQName         string
    RetryDelay      int
}

func Load() *Config {
    if err := godotenv.Load(); err != nil {
        log.Println("No .env file, reading from environment")
    }
    workerCount, _ := strconv.Atoi(getEnv("WORKER_COUNT", "5"))
    retryDelay, _ := strconv.Atoi(getEnv("RETRY_DELAY_SECONDS", "5"))
    return &Config{
        ServerPort:  getEnv("SERVER_PORT", "8080"),
        MetricsPort: getEnv("METRICS_PORT", "8081"),
        DatabaseURL: getEnv("DATABASE_URL", "postgres://jobuser:jobpass@localhost:5432/jobscheduler?sslmode=disable"),
        RabbitMQURL: getEnv("RABBITMQ_URL", "amqp://guest:guest@localhost:5672/"),
        WorkerCount: workerCount,
        QueueName:   getEnv("QUEUE_NAME", "jobs"),
        DLQName:     getEnv("DLQ_NAME", "jobs.dlq"),
        RetryDelay:  retryDelay,
    }
}

func getEnv(key, defaultVal string) string {
    if v := os.Getenv(key); v != "" {
        return v
    }
    return defaultVal
}
