4.9 Service Layer (Clean Architecture)
internal/job/service.go
go
package job

import (
    "context"
    "fmt"

    "job-scheduler/internal/queue"
)

// Service tách business logic ra khỏi handler & repository
type Service struct {
    repo  *Repository
    queue *queue.RabbitMQ
}

func NewService(repo *Repository, q *queue.RabbitMQ) *Service {
    return &Service{repo: repo, queue: q}
}

func (s *Service) CreateJob(ctx context.Context, req *CreateJobRequest) (*Job, error) {
    if req.MaxRetries == 0 {
        req.MaxRetries = 3
    }

    j, err := s.repo.Create(req)
    if err != nil {
        return nil, fmt.Errorf("create job in DB: %w", err)
    }

    msg := JobMessage{JobID: j.ID, Type: j.Type}
    if err := s.queue.Publish(ctx, msg); err != nil {
        // Job đã có trong DB, log để alert team
        // Retry poller sẽ không bắt được vì job vẫn pending không có next_retry_at
        // Production: nên có background check jobs pending quá lâu không được enqueue
        return j, fmt.Errorf("enqueue job: %w", err)
    }

    return j, nil
}

func (s *Service) GetJob(ctx context.Context, id string) (*Job, error) {
    return s.repo.GetByID(id)
}

func (s *Service) ListJobs(ctx context.Context, status string, limit, offset int) ([]*Job, int, error) {
    if limit <= 0 || limit > 100 {
        limit = 20
    }
    return s.repo.List(status, limit, offset)
}
